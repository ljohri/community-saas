# ---------- Frontend (exposed to browser, must start with VITE_) ----------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_APP_NAME="Community Site"

# ---------- Worker / Functions (server-side only, NOT exposed) ----------
# Used by functions/_shared/auth.ts to verify Firebase ID tokens.
# This MUST equal your Firebase project ID. It is not a secret per se,
# but treat env vars as the source of truth.
FIREBASE_PROJECT_ID=

# ---------- Optional: local R2 import (scripts/import_snapshot_r2.py) ----------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=sfbc
